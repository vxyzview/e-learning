# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather

# Authorized Users (comma-separated Telegram user IDs)
# To get your user ID, message @userinfobot on Telegram
AUTHORIZED_USER_IDS=123456789,987654321

# Google Drive Configuration
# Leave empty to upload to root folder, or specify folder ID
GOOGLE_DRIVE_FOLDER_ID=

# Download Settings
MAX_CONCURRENT_DOWNLOADS=2
MAX_FILE_SIZE_MB=2048
DOWNLOAD_PATH=./downloads

# Telegram File Upload Settings
# Free Telegram accounts have ~2GB limit, premium ~4GB
TELEGRAM_FILE_CHUNK_SIZE_MB=2000

# Queue Database
DATABASE_PATH=./bot_queue.db

# Logging
LOG_LEVEL=INFO
